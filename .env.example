# =============================================================================
# Order Intake Agent — environment variables
# =============================================================================
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#
# Nothing in this repo auto-loads .env yet — export the vars manually before
# running, or wire python-dotenv into the entry points when needed:
#
#   export $(grep -v '^#' .env | xargs)        # bash / zsh
#   Get-Content .env | ForEach-Object { ... }  # PowerShell
# =============================================================================


# -----------------------------------------------------------------------------
# LlamaCloud (required by backend/tools/document_parser)
# -----------------------------------------------------------------------------
# Get a key at https://cloud.llamaindex.ai → Settings → API Keys.
# Format: starts with `llx-`. Project-scoped — make sure the key belongs to
# the project you're targeting.
LLAMA_CLOUD_API_KEY=llx-replace-me

# (Optional) Region override.
# Defaults to North America. Set to api.cloud.eu.llamaindex.ai if your key
# was created in the EU region. NA keys do NOT work against the EU endpoint
# and vice versa.
# LLAMA_CLOUD_BASE_URL=
