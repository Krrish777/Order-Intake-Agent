# =============================================================================
# Order Intake Agent — environment variables
# =============================================================================
# Copy this file to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#
# Nothing in this repo auto-loads .env yet — export the vars manually before
# running, or wire python-dotenv into the entry points when needed:
#
#   export $(grep -v '^#' .env | xargs)        # bash / zsh
#   Get-Content .env | ForEach-Object { ... }  # PowerShell
# =============================================================================


# -----------------------------------------------------------------------------
# LlamaCloud (required by backend/tools/document_parser)
# -----------------------------------------------------------------------------
# Get a key at https://cloud.llamaindex.ai → Settings → API Keys.
# Format: starts with `llx-`. Project-scoped — make sure the key belongs to
# the project you're targeting.
LLAMA_CLOUD_API_KEY=llx-replace-me

# (Optional) Region override.
# Defaults to North America. Set to api.cloud.eu.llamaindex.ai if your key
# was created in the EU region. NA keys do NOT work against the EU endpoint
# and vice versa.
# LLAMA_CLOUD_BASE_URL=


# -----------------------------------------------------------------------------
# Firestore (optional - emulator)
# -----------------------------------------------------------------------------
# Point the SDK at a local Firestore emulator. Leave commented out to use
# real Firestore via Application Default Credentials.
# FIRESTORE_EMULATOR_HOST=localhost:8080


# -----------------------------------------------------------------------------
# Google AI / Vertex (used by ADK Gemini calls in the pipeline)
# -----------------------------------------------------------------------------
# AI Studio key (https://aistudio.google.com/apikey) or Vertex setup.
# GOOGLE_API_KEY=replace-me


# -----------------------------------------------------------------------------
# Gmail ingress - Track A1 (polling)
# -----------------------------------------------------------------------------
# Run scripts/gmail_auth_init.py once with a Desktop OAuth credentials.json
# downloaded from Google Cloud Console; paste the three printed lines below.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# (Optional) Polling cadence in seconds (default 30) and dedup label name.
GMAIL_POLL_INTERVAL_SECONDS=30
GMAIL_PROCESSED_LABEL=orderintake-processed


# -----------------------------------------------------------------------------
# Gmail egress - Track A2 (sending replies)
# -----------------------------------------------------------------------------
# Dry-run gates SendStage: when "1" (default), the stage logs what it
# WOULD send and emits an audit event but never calls Gmail. Flip to "0"
# only when you've verified clarify/confirmation bodies look right.
# Production runs should move this through the dry_run -> live cutover
# explicitly (it is NOT auto-disabled).
GMAIL_SEND_DRY_RUN=1


# -----------------------------------------------------------------------------
# Gmail push ingestion - Track A3 (users.watch + Pub/Sub PULL)
# -----------------------------------------------------------------------------
# Required when running scripts/gmail_pubsub_worker.py (the production-shape
# entrypoint). A1's polling script ignores these. Run scripts/gmail_watch_setup.py
# once to create the topic + subscription + grant Gmail's service account
# the publisher role.
GMAIL_PUBSUB_PROJECT_ID=demo-order-intake-local
GMAIL_PUBSUB_TOPIC=gmail-inbox-events
GMAIL_PUBSUB_SUBSCRIPTION=order-intake-ingestion

# (Optional) How often the worker re-asserts users.watch() to keep the push
# subscription alive. Gmail expires watches after 7 days; default is daily.
GMAIL_WATCH_RENEW_INTERVAL_SECONDS=86400

# (Optional) Pub/Sub emulator. Set to localhost:8085 (or wherever you ran
# `gcloud beta emulators pubsub start`) to bypass real Pub/Sub.
# PUBSUB_EMULATOR_HOST=localhost:8085
